NODE_ENV=development
PORT=3000

# Base de donnees PostgreSQL
# Option A: URL complete, utile pour Neon, Railway, Render, Supabase, etc.
DATABASE_URL=

# Option B: configuration detaillee locale
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=cotadise

# Authentification
JWT_SECRET=change-me-with-a-long-random-secret
JWT_EXPIRES_IN=8h
ADMIN_EMAIL=admin@cotadise.example.com
ADMIN_PASSWORD=change-me-with-a-strong-initial-admin-password

# Chiffrement des secrets Wave marchand
WAVE_CONFIG_ENCRYPTION_KEY=change-me-with-32-plus-random-characters
APP_SECRET=change-me-with-a-long-random-secret

# Configuration Wave par defaut ou fallback de test
WAVE_API_KEY=
WAVE_CHECKOUT_URL=https://api.wave.com/v1/checkout/sessions
WAVE_WEBHOOK_SECRET=
WAVE_SUCCESS_URL=https://cotadise.example.com/paiement/succes
WAVE_ERROR_URL=https://cotadise.example.com/paiement/echec

# Emails
EMAIL_DISPATCH_ENABLED=false
EMAIL_DISPATCH_INTERVAL_MS=60000
EMAIL_DISPATCH_BATCH_SIZE=25
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=CotaDISE <noreply@cotadise.example.com>

# URLs publiques
PUBLIC_BACKEND_URL=https://api-cotadise.example.com
PUBLIC_MOBILE_APP_NAME=CotaDISE
CORS_ORIGINS=https://admin-cotadise.example.com

# Donnees de demonstration, a garder false en production
DEMO_SEED_ENABLED=false
